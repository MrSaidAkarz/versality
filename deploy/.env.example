# ── Versality Production Environment ─────────────────────────────────────────
# Copy this file to /opt/versality/.env and fill in real values.
# Never commit the real .env to git.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# Express API port (Nginx proxies /api → this port, don't expose it publicly)
PORT=4000

# Postgres connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://versality:CHANGE_ME@localhost:5432/versality

# Session cookie secret — generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_USE_openssl_rand_hex_32

# Replit Object Storage (if migrating storage; leave blank to disable)
REPLIT_OBJECT_STORAGE_BUCKET=
